class Solution {
    public int missingNumber(int[] nums) {
         int len=nums.length;

        for(int i=0;i<=len;i++) {
            int found = 0;

            for(int j=0;j<len;j++) {
                if(nums[j]==i) {  
                    found=1;
                    break;
                }
            }
            if(found==0) {  
                return i;
            }
        }
        return -1;
    }
}
