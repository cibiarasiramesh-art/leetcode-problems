#include <ctype.h>
#include <stdbool.h>

bool isPalindrome(char* s) {

    int index = 0;
    char arr1[200000];

   
    for(int i = 0; s[i] != '\0'; i++) {
        if(isalnum(s[i])) {
            arr1[index] = tolower(s[i]);
            index++;
        }
    }

    char arr2[200000];
    int index2 = 0;

    for(int i = index - 1; i >= 0; i--) {
        arr2[index2] = arr1[i];
        index2++;
  }
    for(int i = 0; i < index; i++) {
        if(arr1[i] != arr2[i]) {
            return false;
        }
    }

    return true;
}
