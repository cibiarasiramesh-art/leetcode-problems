#include<stdio.h>

#include<stdlib.h>
int main(){
    int n;
    scanf("%d",&n);
    int arr[n];
    
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    int val=0;
    for(int i=0;i<n;i++){
        val=(val*10)+arr[i];
    }
    val=val+1;
    int index=0;
    int *arr1 = calloc(index, sizeof(int));
    int rev=0;
    while(val!=0){
        int rem=val%10;
        
        arr1[index]=rem;
        val=val/10;
        index++;

    }
    printf("[");
    for(int i=index-1;i>=0;i--){
        printf("%d ",arr1[i]);

    }
    printf("]");
}
