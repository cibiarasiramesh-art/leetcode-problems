#include<stdio.h>
int main(){
    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    int count;
    int max=0;
    int maxval=arr[0];
    for(int i=0;i<n;i++){
        count=0;
        for(int j=0;j<n;j++){
            if(arr[i]==arr[j]){
                count++;
                
            }
        }
        
        if(count>max){
            max=count;
            maxval=arr[i];
        }
        
    }
    if(max>n/2){
        printf("%d",maxval);
    }
    else{
        printf("no majority element");
    }
}
