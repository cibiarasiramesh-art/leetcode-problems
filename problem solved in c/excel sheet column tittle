#include <stdio.h>
#include <stdlib.h>

int main() {
    int columnNumber;
    scanf("%d", &columnNumber);

    char result[100];
    int index = 0;

    while (columnNumber > 0) {
        columnNumber--;
        int rem = columnNumber % 26;
        result[index++] = 'A' + rem;
        columnNumber /= 26;
    }

    result[index] = '\0';

    for (int i = 0, j = index - 1; i < j; i++, j--) {
        char temp = result[i];
        result[i] = result[j];
        result[j] = temp;
    }

    printf("%s", result);

    return 0;
}
