#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char* addBinary(char* a, char* b) {
    int i = strlen(a) - 1;
    int j = strlen(b) - 1;
    int carry = 0;

    int maxLen = (strlen(a) > strlen(b) ? strlen(a) : strlen(b)) + 2;
    char* result = (char*)malloc(maxLen * sizeof(char));
    int k = 0;

    while (i >= 0 || j >= 0 || carry) {
        int sum = carry;

        if (i >= 0) sum += a[i--] - '0';
        if (j >= 0) sum += b[j--] - '0';

        result[k++] = (sum % 2) + '0';
        carry = sum / 2;
    }

    result[k] = '\0';

    // reverse the result
    for (int x = 0; x < k / 2; x++) {
        char temp = result[x];
        result[x] = result[k - x - 1];
        result[k - x - 1] = temp;
    }

    return result;
}
